{
  "manifest_version": 3,
  "name": "RecipeClip",
  "version": "1.0.0",
  "description": "Save recipes from any website to your RecipeClip library in one click.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "RecipeClip",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "permissions": [
    "storage",
    "activeTab",
    "contextMenus",
    "sidePanel",
    "scripting"
  ],
  "host_permissions": [
    "https://recipeclip.app/*"
  ],
  "externally_connectable": {
    "matches": ["https://recipeclip.app/*"]
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+R",
        "mac": "Command+Shift+R"
      },
      "description": "Open RecipeClip popup"
    }
  }
}
